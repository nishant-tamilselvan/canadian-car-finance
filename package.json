{
  "name": "canadian-car-finance",
  "version": "0.2.1",
  "description": "Canadian car financing & leasing calculation utilities — amortization, lease formulas, provincial taxes, and dealer fee analysis",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "canada",
    "car",
    "auto",
    "lease",
    "finance",
    "loan",
    "amortization",
    "calculator",
    "amvic",
    "alberta",
    "provincial-tax",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Nishant Tamilselvan (https://github.com/nishant-tamilselvan)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nishant-tamilselvan/canadian-car-finance.git"
  },
  "homepage": "https://github.com/nishant-tamilselvan/canadian-car-finance#readme",
  "bugs": {
    "url": "https://github.com/nishant-tamilselvan/canadian-car-finance/issues"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~5.8.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
